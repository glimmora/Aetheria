# ============================================================
# Mythral — Environment Configuration
# Copy this file to .env and customize for your deployment.
# All values have sensible defaults for development.
# ============================================================

# ---- Backend (server) Network ----
# Host to bind the server to. Use 0.0.0.0 for all interfaces (Docker/VPS),
# 127.0.0.1 for localhost-only.
HOST=0.0.0.0

# Port the backend server listens on.
PORT=12400

# ---- Frontend (client) Network ----
# Vite dev server host (use 0.0.0.0 for LAN/mobile testing)
VITE_DEV_HOST=0.0.0.0
# Vite dev server port (the frontend players connect to)
VITE_DEV_PORT=12000
# Vite preview (production build) port
VITE_PREVIEW_PORT=12100

# ---- Cross-origin (CORS) ----
# The origin of your frontend. In development, leave as localhost:12000.
# In production, set to your exact domain (https://your-domain.com).
# When NODE_ENV=production, CORS is restricted to this value only.
CLIENT_ORIGIN=http://localhost:12000

# For the frontend: the backend URL to connect to.
# In dev with Vite proxy, this is used for socket.io and direct API calls.
# In split deployment, set to your server URL.
VITE_SERVER_URL=http://localhost:12400

# ---- Security ----
# Secret used to sign JWT tokens. MUST be changed in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# JWT token expiry (e.g., 7d, 24h, 1h)
JWT_EXPIRES_IN=7d

# Bcrypt rounds for password hashing (10 = ~100ms per hash, 12 = ~400ms)
BCRYPT_ROUNDS=10

# ---- Environment ----
# Set to 'production' for optimized mode (stricter CORS, no verbose logs)
NODE_ENV=development

# ---- Leveling System ----
# Maximum level a character can reach.
MAX_LEVEL=100

# XP curve: xpForLevel(n) = XP_CURVE_BASE * XP_CURVE_GROWTH^n
# Default: 128 * 1.16^n → ~2.23 billion total XP to reach level 100
#
# At 2000 XP/min average (realistic mid+late game): ~12.7 years at 4hr/day
# At 3000 XP/min average (optimistic endgame):     ~8.5 years at 4hr/day
# → Average: ~10 years to reach level 100
#
# To make leveling faster, increase GROWTH (e.g., 1.15 = ~5 years)
# To make it slower, decrease GROWTH (e.g., 1.17 = ~20 years)
# To shift the whole curve up/down, adjust BASE
XP_CURVE_BASE=128
XP_CURVE_GROWTH=1.16

# ---- Rate Limiting ----
# Auth endpoints (login/register) per IP per 15 minutes
AUTH_RATE_LIMIT_PER_15MIN=20
# General socket events per IP per minute
GENERAL_RATE_LIMIT_PER_MIN=120

# ---- Gameplay Tunables ----
# Movement cooldown in ms (lower = faster movement)
MOVE_COOLDOWN_MS=140
# Basic attack cooldown in ms
ATTACK_COOLDOWN_MS=700
# Percentage of gold lost on death
RESPAWN_HP_PENALTY_GOLD_PCT=10
# Max inventory slots per character
MAX_INVENTORY_SLOTS=60
# Starting gold for new characters
STARTING_GOLD=50

# ---- Chat ----
CHAT_MAX_LENGTH=200
CHAT_COOLDOWN_MS=1000

# ---- Account ----
MAX_CHARACTERS_PER_ACCOUNT=5

# ---- Server Operations ----
# Autosave interval (ms) — how often to save all characters
AUTOSAVE_INTERVAL_MS=30000
# How often to broadcast online players list
ONLINE_BROADCAST_INTERVAL_MS=5000
# How often to clean up stale sessions
STALE_SESSION_CLEANUP_INTERVAL_MS=60000

# ---- Leaderboard ----
LEADERBOARD_SIZE=50

# ---- Monster Respawns ----
# Min/max respawn time for normal monsters (ms)
MONSTER_RESPAWN_MIN_MS=60000
MONSTER_RESPAWN_MAX_MS=120000
# Boss respawn time (ms)
BOSS_RESPAWN_MS=120000

# ---- Game Tick ----
# Server tick rate (Hz) — how often monster AI updates
TICK_RATE_HZ=10

# ---- Socket.io ----
# Heartbeat intervals (ms)
SOCKET_PING_INTERVAL=10000
SOCKET_PING_TIMEOUT=5000

# ---- HTTP ----
# Express body size limit
BODY_LIMIT=64kb

# ---- Reserved for future ----
SESSION_TIMEOUT_MS=300000
AUTH_RATE_LIMIT_WINDOW_MS=900000
