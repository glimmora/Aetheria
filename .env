# Mythral development environment
# This file is gitignored — do not commit real secrets.

# Server
HOST=0.0.0.0
PORT=4000
NODE_ENV=development

# Client
VITE_DEV_HOST=0.0.0.0
VITE_DEV_PORT=5173
VITE_SERVER_URL=http://localhost:4000

# CORS (dev — allow Vite proxy to work)
CLIENT_ORIGIN=http://localhost:5173

# Security (change in production!)
JWT_SECRET=dev-secret-not-for-production-use-a-real-one-please-64chars
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# Rate limits
AUTH_RATE_LIMIT_PER_15MIN=20
GENERAL_RATE_LIMIT_PER_MIN=120

# Gameplay
MOVE_COOLDOWN_MS=140
ATTACK_COOLDOWN_MS=700
RESPAWN_HP_PENALTY_GOLD_PCT=10
MAX_INVENTORY_SLOTS=60
STARTING_GOLD=50

# Chat
CHAT_MAX_LENGTH=200
CHAT_COOLDOWN_MS=1000

# Account
MAX_CHARACTERS_PER_ACCOUNT=5

# Server ops
AUTOSAVE_INTERVAL_MS=30000
ONLINE_BROADCAST_INTERVAL_MS=5000
STALE_SESSION_CLEANUP_INTERVAL_MS=60000
LEADERBOARD_SIZE=50

# Monster respawns
MONSTER_RESPAWN_MIN_MS=60000
MONSTER_RESPAWN_MAX_MS=120000
BOSS_RESPAWN_MS=120000

# Tick
TICK_RATE_HZ=10

# Socket.io
SOCKET_PING_INTERVAL=10000
SOCKET_PING_TIMEOUT=5000

# HTTP
BODY_LIMIT=64kb
